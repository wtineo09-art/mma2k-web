---
import MainLayout from '../layouts/MainLayout.astro';

export const prerender = false;

const { slug } = Astro.params;

// Intentamos buscar el post en WordPress
const response = await fetch(`https://mma2k.com/wp-json/wp/v2/posts?slug=${slug}&_embed`);
const posts = await response.json();
const post = posts[0];

// Si no hay post, mandamos al 404 de Astro
if (!post) {
  return Astro.redirect('/404');
}
---

<MainLayout title={post.title.rendered}>
    <main class="max-w-4xl mx-auto px-6 py-20">
        <header class="mb-12">
            <h1 class="text-6xl font-black uppercase italic tracking-tighter" set:html={post.title.rendered} />
            <p class="text-red-600 mt-4 font-bold uppercase italic">{new Date(post.date).toLocaleDateString()}</p>
        </header>

        {post._embedded?.['wp:featuredmedia'] && (
            <img 
                src={post._embedded['wp:featuredmedia'][0].source_url} 
                class="w-full rounded-[2rem] mb-12 shadow-2xl" 
                alt=""
            />
        )}

        <div class="prose prose-invert max-w-none text-gray-300 text-xl italic wp-content" set:html={post.content.rendered} />
    </main>
</MainLayout>

<style is:global>
    .wp-content p { margin-bottom: 1.5rem; }
    .wp-content img { border-radius: 1.5rem; margin: 2rem 0; }
</style>
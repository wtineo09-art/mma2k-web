---
import MainLayout from '../layouts/MainLayout.astro';
export const prerender = false;

const { slug } = Astro.params;

// Buscamos el post por slug
const response = await fetch(`https://mma2k.com/wp-json/wp/v2/posts?slug=${slug}&_embed`);
const posts = await response.json();
const post = posts[0];

// Si no existe, mandamos a 404
if (!post) {
  return Astro.redirect('/404');
}
---
<MainLayout title={post.title.rendered}>
    <article class="max-w-4xl mx-auto px-6 py-20 text-white">
        <h1 class="text-6xl font-black uppercase italic" set:html={post.title.rendered} />
        <div class="mt-10 prose prose-invert max-w-none italic" set:html={post.content.rendered} />
    </article>
</MainLayout>
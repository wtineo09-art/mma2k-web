---
import MainLayout from '../layouts/MainLayout.astro';

export const prerender = false; // Esto permite que busque en WP cada vez que alguien entra

const { slug } = Astro.params;

// 1. CONEXIÓN CON LA API DE WORDPRESS
const url = `https://mma2k.com/wp-json/wp/v2/posts?slug=${slug}&_embed`;
const response = await fetch(url);
const posts = await response.json();
const post = posts[0];

// 2. CONTROL DE ERRORES (Si no hay nada, no muestra pantalla blanca)
if (!post) {
  return Astro.redirect('/404');
}

// Extraemos la imagen destacada de forma segura
const image = post._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
---

<MainLayout title={post.title.rendered}>
    <article class="max-w-4xl mx-auto px-6 py-20 text-white">
        
        <header class="mb-12 space-y-4">
            <h1 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter leading-none" 
                set:html={post.title.rendered} />
            <div class="h-1 w-20 bg-red-600"></div>
        </header>

        {image && (
            <div class="rounded-3xl overflow-hidden mb-16 shadow-2xl border border-white/10">
                <img src={image} class="w-full h-auto object-cover" alt="" />
            </div>
        )}

        <div class="prose prose-invert max-w-none text-gray-300 text-xl italic wp-content" 
             set:html={post.content.rendered} />

    </article>
</MainLayout>

<style is:global>
    /* Estilos para que el texto de WordPress se vea bien en Astro */
    .wp-content p { margin-bottom: 2rem; line-height: 1.8; }
    .wp-content h2 { color: white; font-size: 2.5rem; font-weight: 900; margin-top: 3rem; text-transform: uppercase; font-style: italic; }
    .wp-content img { border-radius: 1.5rem; margin: 2rem 0; width: 100%; height: auto; }
</style>
---
import MainLayout from '../../layouts/MainLayout.astro';

// Forzamos a que Astro trate esto como una página de servidor
export const prerender = false;

const { slug } = Astro.params;

// 1. Limpiamos el slug por si trae caracteres raros
const cleanSlug = encodeURIComponent(slug);

// 2. Buscamos en WordPress
const response = await fetch(`https://mma2k.com/wp-json/wp/v2/posts?slug=${cleanSlug}&_embed`);
const posts = await response.json();
const post = posts[0];

if (!post) {
  return Astro.redirect('/404');
}
---

<MainLayout title={post.title.rendered}>
    <article class="max-w-4xl mx-auto px-6 py-20">
        <header class="mb-12 text-center">
            <h1 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter leading-none" set:html={post.title.rendered} />
            <p class="text-red-600 mt-6 font-black italic uppercase italic tracking-widest">
                {new Date(post.date).toLocaleDateString()}
            </p>
        </header>

        {post._embedded?.['wp:featuredmedia'] && (
            <div class="rounded-[2.5rem] overflow-hidden mb-16 border border-white/5 shadow-2xl">
                <img src={post._embedded['wp:featuredmedia'][0].source_url} class="w-full h-auto" />
            </div>
        )}

        <div class="prose prose-invert max-w-none text-gray-300 text-lg italic leading-relaxed wp-content" set:html={post.content.rendered} />
    </article>
</MainLayout>

<style is:global>
    .wp-content p { margin-bottom: 1.5rem; }
    .wp-content img { border-radius: 1rem; margin: 2rem 0; }
</style>
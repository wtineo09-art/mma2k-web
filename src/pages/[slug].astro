---
import MainLayout from '../layouts/MainLayout.astro';

export const prerender = false;

const { slug } = Astro.params;

const response = await fetch(`https://mma2k.com/wp-json/wp/v2/posts?slug=${slug}&_embed`);
const posts = await response.json();
const post = posts[0];

if (!post) {
  return Astro.redirect('/404');
}
---

<MainLayout title={post.title.rendered}>
    <article class="max-w-4xl mx-auto px-6 py-20">
        <header class="mb-16 space-y-6 text-center">
            <h1 class="text-6xl md:text-8xl font-black uppercase italic tracking-tighter leading-none" set:html={post.title.rendered} />
            <p class="text-red-600 font-black italic uppercase tracking-widest">
                {new Date(post.date).toLocaleDateString()}
            </p>
        </header>

        {post._embedded?.['wp:featuredmedia'] && (
            <div class="rounded-[3rem] overflow-hidden mb-20 border border-white/10 shadow-2xl">
                <img src={post._embedded['wp:featuredmedia'][0].source_url} class="w-full h-auto" />
            </div>
        )}

        <div class="prose prose-invert max-w-none text-gray-300 text-xl italic leading-relaxed wp-content" set:html={post.content.rendered} />
    </article>
</MainLayout>

<style is:global>
    .wp-content p { margin-bottom: 2rem; }
    .wp-content img { border-radius: 2rem; margin: 3rem 0; border: 1px solid rgba(255,255,255,0.1); }
</style>
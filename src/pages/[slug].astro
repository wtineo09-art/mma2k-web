---
import MainLayout from '../layouts/MainLayout.astro';

export const prerender = false;

const { slug } = Astro.params;

// Llamada directa a WordPress usando el slug
const response = await fetch(`https://mma2k.com/wp-json/wp/v2/posts?slug=${slug}&_embed`);
const posts = await response.json();
const post = posts[0];

if (!post) {
  return Astro.redirect('/404');
}
---

<MainLayout title={post.title.rendered}>
    <article class="max-w-4xl mx-auto px-6 py-20">
        <header class="mb-10 text-center">
            <h1 class="text-6xl md:text-8xl font-black uppercase italic tracking-tighter leading-none text-white" set:html={post.title.rendered} />
            <p class="text-red-600 font-bold mt-4 uppercase italic">MMA2K EXCLUSIVE</p>
        </header>

        {post._embedded?.['wp:featuredmedia'] && (
            <div class="rounded-3xl overflow-hidden mb-12 shadow-2xl border border-white/10">
                <img src={post._embedded['wp:featuredmedia'][0].source_url} class="w-full h-auto" alt="" />
            </div>
        )}

        <div class="prose prose-invert max-w-none text-gray-300 text-xl italic leading-relaxed wp-content" set:html={post.content.rendered} />
    </article>
</MainLayout>

<style is:global>
    .wp-content p { margin-bottom: 2rem; }
    .wp-content img { border-radius: 1.5rem; margin: 3rem 0; border: 1px solid rgba(255,255,255,0.1); }
    .wp-content h2 { color: white; text-transform: uppercase; font-weight: 900; font-style: italic; margin-top: 3rem; font-size: 2rem; }
</style>
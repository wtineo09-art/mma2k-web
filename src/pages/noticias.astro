---
import MainLayout from '../layouts/MainLayout.astro';
export const prerender = false;

const response = await fetch("https://mma2k.com/wp-json/wp/v2/posts?_embed&per_page=10");
const noticias = await response.json();
---
<MainLayout title="Noticias | MMA2K">
    <main class="max-w-7xl mx-auto py-20 px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            {noticias.map((post) => (
                <a href={`/${post.slug}`} class="group block">
                    <h2 class="text-xl font-black uppercase italic text-white group-hover:text-red-600 italic" set:html={post.title.rendered} />
                </a>
            ))}
        </div>
    </main>
</MainLayout>
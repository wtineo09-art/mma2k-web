---
import MainLayout from '../layouts/MainLayout.astro';

export const prerender = false;

// Traemos 10 noticias de tu WordPress
const response = await fetch("https://mma2k.com/wp-json/wp/v2/posts?_embed&per_page=10");
const noticias = await response.json();
---

<MainLayout title="Noticias | MMA2K">
    <main class="max-w-7xl mx-auto px-6 py-20">
        <h1 class="text-7xl font-black uppercase italic mb-16 italic">FEED DE <span class="text-red-600">NOTICIAS</span></h1>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            {noticias.map((post) => (
                <a href={`/${post.slug}`}>
                    <div class="aspect-video rounded-[2rem] overflow-hidden mb-6 border border-white/5 bg-[#111]">
                        <img 
                            src={post._embedded?.['wp:featuredmedia']?.[0].source_url || "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800"} 
                            class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700" 
                        />
                    </div>
                    <p class="text-red-600 font-black text-[10px] uppercase italic tracking-widest mb-2">MMA2K • OFICIAL</p>
                    <h2 class="text-2xl font-black uppercase italic tracking-tighter group-hover:text-red-500 transition-colors leading-none italic" set:html={post.title.rendered} />
                </a>
            ))}
        </div>
    </main>
</MainLayout>
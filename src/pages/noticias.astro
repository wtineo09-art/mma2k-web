---
import MainLayout from '../layouts/MainLayout.astro';

// 1. LA CONEXIÓN: Cambia "mma2k.com" por tu URL real de WordPress
const WP_URL = "https://mma2k.com/wp-json/wp/v2/posts?_embed&per_page=10";

// Traemos los datos de la base de datos de WP
const response = await fetch(WP_URL);
const noticias = await response.json();
---

<MainLayout title="Feed de Noticias Reales">
    <main class="max-w-7xl mx-auto px-6 py-20">
        
        <div class="mb-20 border-b-8 border-red-600 pb-8 inline-block">
            <h1 class="text-7xl font-black uppercase italic tracking-tighter italic">NOTICIAS <span class="text-red-600">RECIENTES</span></h1>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            
            <div class="lg:col-span-8 space-y-16">
                {noticias.map((post) => (
                    <article class="group flex flex-col md:flex-row gap-10 border-b border-white/5 pb-16 last:border-0">
                        
                        <div class="w-full md:w-80 aspect-video rounded-3xl overflow-hidden shrink-0 border border-white/5 bg-[#111]">
                            {post._embedded && post._embedded['wp:featuredmedia'] ? (
                                <img 
                                    src={post._embedded['wp:featuredmedia'][0].source_url} 
                                    class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700" 
                                    alt={post.title.rendered}
                                />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-gray-800 font-black italic">NO IMAGE</div>
                            )}
                        </div>

                        <div class="space-y-4">
                            <p class="text-red-600 font-black text-[10px] uppercase italic tracking-widest">
                                {new Date(post.date).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' })}
                            </p>
                            
                            <h2 class="text-3xl font-black uppercase italic leading-none group-hover:text-red-500 transition-all italic tracking-tighter">
                                <span set:html={post.title.rendered} />
                            </h2>

                            <div class="text-gray-500 text-sm font-medium italic leading-relaxed line-clamp-2" set:html={post.excerpt.rendered} />
                            
                            <a href={`/post/${post.slug}`} class="inline-block text-[10px] font-black uppercase tracking-widest border-b border-red-600 pb-1 hover:text-red-600 transition-colors">
                                LEER ARTÍCULO COMPLETO →
                            </a>
                        </div>
                    </article>
                ))}
            </div>

            <aside class="lg:col-span-4 space-y-12">
                <div class="bg-[#111] p-10 rounded-[3rem] border border-white/5">
                    <h3 class="text-xl font-black uppercase italic mb-8 border-l-4 border-red-600 pl-4 italic">LO MÁS <span class="text-red-600">LEÍDO</span></h3>
                    <p class="text-gray-600 text-[10px] font-black uppercase italic">Contenido de WordPress cargando...</p>
                </div>
            </aside>
        </div>
    </main>
</MainLayout>
---
import MainLayout from '../layouts/MainLayout.astro';

// Simulamos los datos que traeremos de WordPress después
const resultadoEvento = {
    titulo: "RESULTADOS UFC 326: TOPURIA VS HOLLOWAY",
    fecha: "15 de Agosto, 2026",
    estelar: {
        ganador: "Ilia Topuria",
        perdedor: "Max Holloway",
        metodo: "KO (Ganchos al cuerpo)",
        round: "3",
        tiempo: "2:45"
    },
    otrosResultados: [
        { g: "Merab Dvalishvili", p: "Sean O'Malley", m: "Decisión Unánime", r: "5" },
        { g: "Paddy Pimblett", p: "Renato Moicano", m: "Sumisión (RNC)", r: "2" },
        { g: "Kayla Harrison", p: "Larissa Pacheco", m: "Decisión Unánime", r: "3" }
    ]
};
---

<MainLayout title={resultadoEvento.titulo}>
    <main class="max-w-5xl mx-auto px-6 py-16">
        
        <div class="text-center mb-20">
            <span class="bg-red-600 text-[10px] font-black px-4 py-1.5 rounded uppercase italic tracking-[0.3em] mb-6 inline-block italic">Official Results</span>
            <h1 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter leading-none mb-6 italic">{resultadoEvento.titulo}</h1>
            <p class="text-gray-500 font-bold uppercase tracking-widest text-xs italic">{resultadoEvento.fecha} • Santiago Bernabéu</p>
        </div>

        <section class="bg-white text-black p-1 rounded-3xl overflow-hidden shadow-[0_0_50px_rgba(255,255,255,0.1)] mb-16">
            <div class="bg-black p-12 rounded-[1.4rem] border border-white/10 flex flex-col md:flex-row items-center justify-between gap-12">
                
                <div class="text-center md:text-left">
                    <p class="text-red-600 font-black italic text-xs uppercase mb-2 italic">And Still Champion</p>
                    <h2 class="text-5xl font-black uppercase italic tracking-tighter mb-4 italic">{resultadoEvento.estelar.ganador}</h2>
                    <span class="bg-green-500 text-black text-[10px] font-black px-3 py-1 uppercase italic italic">WINNER</span>
                </div>

                <div class="flex flex-col items-center">
                    <p class="text-gray-600 font-black italic text-4xl mb-2 italic">VS</p>
                    <div class="h-10 w-[2px] bg-red-600"></div>
                </div>

                <div class="text-center md:text-right opacity-40 grayscale">
                    <p class="text-gray-500 font-black italic text-xs uppercase mb-2 italic">Challenger</p>
                    <h2 class="text-5xl font-black uppercase italic tracking-tighter mb-4 italic">{resultadoEvento.estelar.perdedor}</h2>
                </div>
            </div>
            
            <div class="grid grid-cols-3 bg-white py-6 text-black text-center border-t border-gray-200">
                <div><p class="text-[9px] font-black uppercase text-gray-400">Método</p><p class="font-black italic uppercase italic">{resultadoEvento.estelar.metodo}</p></div>
                <div class="border-x border-gray-200"><p class="text-[9px] font-black uppercase text-gray-400">Round</p><p class="font-black italic uppercase italic">{resultadoEvento.estelar.round}</p></div>
                <div><p class="text-[9px] font-black uppercase text-gray-400">Tiempo</p><p class="font-black italic uppercase italic">{resultadoEvento.estelar.tiempo}</p></div>
            </div>
        </section>

        <section class="space-y-4">
            <h3 class="text-2xl font-black uppercase italic tracking-widest mb-8 border-l-4 border-red-600 pl-4 italic">Resultados de la <span class="text-red-600 text-red-600">Cartelera</span></h3>
            
            {resultadoEvento.otrosResultados.map((res) => (
                <div class="bg-[#111] p-6 rounded-2xl border border-white/5 flex flex-col md:flex-row justify-between items-center group hover:border-white/20 transition-all">
                    <div class="flex items-center gap-4">
                        <div class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.5)]"></div>
                        <p class="text-lg font-black uppercase italic italic tracking-tighter">{res.g}</p>
                    </div>
                    
                    <div class="py-2 px-6 bg-black rounded-full border border-white/5 text-[9px] font-black text-gray-500 uppercase italic my-4 md:my-0">
                        Defeated via {res.m} (R{res.r})
                    </div>

                    <div class="flex items-center gap-4 opacity-30">
                        <p class="text-lg font-black uppercase italic italic tracking-tighter">{res.p}</p>
                        <div class="w-2 h-2 rounded-full bg-red-600"></div>
                    </div>
                </div>
            ))}
        </section>

    </main>
</MainLayout>
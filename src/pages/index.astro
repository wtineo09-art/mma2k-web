---
import MainLayout from '../layouts/MainLayout.astro';

export const prerender = false;

const response = await fetch("https://mma2k.com/wp-json/wp/v2/posts?_embed&per_page=6");
const noticias = await response.json();
---

<MainLayout title="MMA2K | The Fight Portal">
    <main class="max-w-7xl mx-auto py-20 px-6">
        <h2 class="text-7xl font-black uppercase italic mb-16 tracking-tighter text-white italic">ÚLTIMAS <span class="text-red-600">NOTICIAS</span></h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            {noticias.map((item) => (
                <a href={`/${item.slug}`} class="group block">
                    <div class="aspect-video overflow-hidden rounded-[2rem] mb-6 bg-neutral-900 border border-white/5">
                        {item._embedded?.['wp:featuredmedia']?.[0].source_url && (
                            <img 
                                src={item._embedded['wp:featuredmedia'][0].source_url} 
                                class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700 opacity-80 group-hover:opacity-100" 
                            />
                        )}
                    </div>
                    <p class="text-red-600 font-black text-[10px] uppercase italic tracking-[0.2em] mb-3 italic">MMA2K • OFICIAL</p>
                    <h3 class="text-2xl font-black uppercase italic tracking-tighter leading-none text-white group-hover:text-red-600 transition-colors italic" set:html={item.title.rendered} />
                </a>
            ))}
        </div>
    </main>
</MainLayout>
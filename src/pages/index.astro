---
import MainLayout from '../layouts/MainLayout.astro';

export const prerender = false;

const response = await fetch("https://mma2k.com/wp-json/wp/v2/posts?_embed&per_page=10");
const noticiasWP = await response.json();

const heroPosts = noticiasWP.slice(0, 3);
const mainFeatured = noticiasWP[0];
const sidePosts = noticiasWP.slice(3, 6);
const masNoticias = noticiasWP.slice(6, 10);
---

<MainLayout title="The Fight Portal | Home">
    
    <section class="grid grid-cols-1 md:grid-cols-3 w-full bg-black border-b border-white/10">
        {heroPosts.map((post, index) => (
            <a href={`/${post.slug}`} class={`relative h-[350px] border-b-4 ${index === 0 ? 'border-red-600' : 'border-gray-800'} group cursor-pointer overflow-hidden block`}>
                <img src={post._embedded?.['wp:featuredmedia']?.[0].source_url} class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-110 transition-all duration-1000" />
                <div class="absolute bottom-0 p-8 z-10">
                    <h2 class="text-2xl font-black leading-none uppercase italic group-hover:text-red-500 transition-colors" set:html={post.title.rendered} />
                </div>
            </a>
        ))}
    </section>

    <main class="max-w-7xl mx-auto px-6 py-20 space-y-20">
        <section class="grid grid-cols-1 lg:grid-cols-12 gap-0 bg-white text-black overflow-hidden shadow-2xl rounded-sm">
            <div class="lg:col-span-8 relative flex flex-col bg-gray-100">
                <div class="h-[550px] overflow-hidden">
                    <img src={mainFeatured._embedded?.['wp:featuredmedia']?.[0].source_url} class="w-full h-full object-cover" />
                </div>
                <div class="p-10 bg-white md:-mt-32 md:ml-12 md:mb-12 relative z-10 shadow-2xl max-w-2xl border-l-[15px] border-red-600">
                    <h2 class="text-6xl font-black uppercase italic leading-[0.85] mb-6 tracking-tighter" set:html={mainFeatured.title.rendered} />
                    <a href={`/${mainFeatured.slug}`} class="bg-black text-white px-10 py-5 text-[11px] font-black uppercase italic tracking-widest hover:bg-red-600 transition-all inline-block">LEER MÁS</a>
                </div>
            </div>

            <div class="lg:col-span-4 bg-[#0a0a0a] text-white p-12">
                <h3 class="text-3xl font-black uppercase italic tracking-tighter mb-16 border-b-2 border-red-600 pb-4">TOP STORIES</h3>
                <div class="space-y-12">
                    {sidePosts.map((s, index) => (
                        <a href={`/${s.slug}`} class="group flex items-start gap-6 cursor-pointer block">
                            <div class="bg-red-600 w-12 h-12 flex items-center justify-center text-2xl font-black italic shrink-0">{index + 4}</div>
                            <h4 class="text-lg font-black uppercase tracking-tighter italic leading-none group-hover:text-red-500 transition-colors" set:html={s.title.rendered} />
                        </a>
                    ))}
                </div>
            </div>
        </section>
    </main>
</MainLayout>
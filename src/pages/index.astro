---
import MainLayout from '../layouts/MainLayout.astro';
export const prerender = false;

// Traemos las últimas 6 noticias
const response = await fetch("https://mma2k.com/wp-json/wp/v2/posts?_embed&per_page=6");
const noticias = await response.json();
---

<MainLayout title="MMA2K | OFICIAL">
    <main class="max-w-7xl mx-auto py-20 px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            {noticias.map((item) => (
                <a href={`/${item.slug}`} class="group block border-b border-white/5 pb-10">
                    <div class="aspect-video overflow-hidden rounded-2xl mb-6 bg-neutral-900">
                        <img src={item._embedded?.['wp:featuredmedia']?.[0]?.source_url} 
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-80" />
                    </div>
                    <h2 class="text-3xl font-black uppercase italic text-white group-hover:text-red-600" 
                        set:html={item.title.rendered} />
                </a>
            ))}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
    {noticias && noticias.length > 0 && noticias.map((item) => (
        <a href={`/${item.slug}`} class="group block">
            {/* ... resto del código ... */}
        </a>
    ))}
</div>
    </main>
</MainLayout>
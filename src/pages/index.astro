---
import MainLayout from '../layouts/MainLayout.astro';

// 1. TRAEMOS LOS POSTS
const WP_URL = "https://mma2k.com/wp-json/wp/v2/posts?_embed&per_page=10";
const response = await fetch(WP_URL);
const noticiasWP = await response.json();

// 2. REPARTIMOS LOS DATOS
const heroPosts = noticiasWP.slice(0, 3);
const mainFeatured = noticiasWP[0];
const sidePosts = noticiasWP.slice(3, 6);
const masNoticias = noticiasWP.slice(6, 10);
---

<MainLayout title="The Fight Portal | Home">
    
    <section class="grid grid-cols-1 md:grid-cols-3 w-full bg-black border-b border-white/10">
        {heroPosts.map((post, index) => (
            <div class={`relative h-[350px] border-b-4 ${index === 0 ? 'border-red-600' : 'border-gray-800'} group cursor-pointer overflow-hidden`}>
                <img 
                    src={post._embedded?.['wp:featuredmedia']?.[0].source_url || "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800"} 
                    class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-110 transition-all duration-1000 group-hover:opacity-60" 
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
                <div class="absolute bottom-0 p-8">
                    <p class="text-[10px] font-black text-red-600 mb-2 uppercase italic tracking-widest">
                        {new Date(post.date).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' })}
                    </p>
                    <h2 class="text-2xl font-black leading-[0.9] uppercase italic tracking-tighter group-hover:text-red-500 transition-colors" set:html={post.title.rendered} />
                </div>
            </div>
        ))}
    </section>

    <main class="max-w-7xl mx-auto px-6 py-20 space-y-32">
        
        <section class="grid grid-cols-1 lg:grid-cols-12 gap-0 bg-white text-black overflow-hidden shadow-2xl rounded-sm">
            <div class="lg:col-span-8 relative flex flex-col bg-gray-100">
                <div class="h-[550px] overflow-hidden">
                    <img src={mainFeatured._embedded?.['wp:featuredmedia']?.[0].source_url || "https://images.unsplash.com/photo-1595079676339-1534801ad6cf?q=80&w=1200"} class="w-full h-full object-cover" />
                </div>
                <div class="p-10 bg-white md:-mt-32 md:ml-12 md:mb-12 relative z-10 shadow-2xl max-w-2xl border-l-[15px] border-red-600">
                    <h2 class="text-6xl font-black uppercase italic leading-[0.85] mb-6 tracking-tighter" set:html={mainFeatured.title.rendered} />
                    <div class="text-gray-600 text-sm font-bold uppercase mb-8 italic leading-relaxed line-clamp-3" set:html={mainFeatured.excerpt.rendered} />
                    <a href={`/articulo/${post.slug}`} ...> class="bg-black text-white px-10 py-5 text-[11px] font-black uppercase italic tracking-widest hover:bg-red-600 transition-all inline-block">LEER MÁS</a>
                </div>
            </div>

            <div class="lg:col-span-4 bg-[#0a0a0a] text-white p-12">
                <h3 class="text-3xl font-black uppercase italic tracking-tighter mb-16 border-b-2 border-red-600 pb-4 italic">TOP <span class="text-red-600">STORIES</span></h3>
                <div class="space-y-12">
                    {sidePosts.map((s, index) => (
                        <a href={`/post/${s.slug}`} class="group flex items-start gap-6 cursor-pointer block">
                            <div class="bg-red-600 w-12 h-12 flex items-center justify-center text-2xl font-black italic shrink-0 group-hover:scale-110 transition-all">{index + 4}</div>
                            <div>
                                <p class="text-[9px] font-black text-gray-500 uppercase italic tracking-widest mb-1">ÚLTIMA HORA</p>
                                <h4 class="text-lg font-black uppercase tracking-tighter italic leading-none group-hover:text-red-500 transition-colors" set:html={s.title.rendered} />
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>

        <section class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            <div class="lg:col-span-8">
                <h3 class="text-3xl font-black uppercase italic tracking-tighter mb-10 flex items-center gap-4 italic">
                    <span class="w-1 h-8 bg-red-600"></span> MÁS <span class="text-red-600">NOTICIAS</span>
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    {masNoticias.map((n) => (
                        <a href={`/post/${n.slug}`} class="group block">
                            <div class="aspect-video rounded-2xl overflow-hidden mb-6 border border-white/5 bg-[#111]">
                                <img 
                                    src={n._embedded?.['wp:featuredmedia']?.[0].source_url || "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800"} 
                                    class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700" 
                                />
                            </div>
                            <p class="text-red-600 font-black text-[9px] uppercase italic tracking-widest mb-2">MMA2K • RECIENTE</p>
                            <h4 class="text-xl font-black uppercase italic tracking-tighter group-hover:text-white text-gray-300 leading-tight italic" set:html={n.title.rendered} />
                        </a>
                    ))}
                </div>
            </div>

            <aside class="lg:col-span-4">
                <div class="bg-[#111] p-10 rounded-[2.5rem] border border-white/5 h-fit">
                    <h3 class="text-2xl font-black uppercase italic mb-10 italic">ÚNETE A LA <span class="text-red-600">JAULA</span></h3>
                    <div class="space-y-4">
                        <a href="#" class="flex items-center justify-between p-6 bg-white/5 rounded-2xl hover:bg-white/10 transition-all group">
                            <span class="text-[11px] font-black uppercase italic tracking-widest group-hover:text-red-500">INSTAGRAM</span>
                            <span class="text-[10px] text-gray-500 font-bold italic">85K Followers</span>
                        </a>
                        <a href="#" class="flex items-center justify-between p-6 bg-white/5 rounded-2xl hover:bg-white/10 transition-all group">
                            <span class="text-[11px] font-black uppercase italic tracking-widest group-hover:text-red-500">YOUTUBE</span>
                            <span class="text-[10px] text-gray-500 font-bold italic">150K Subs</span>
                        </a>
                    </div>
                </div>
            </aside>
        </section> </main> </MainLayout>
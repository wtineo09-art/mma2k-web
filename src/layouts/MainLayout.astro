---
import '../styles/global.css';
const { title } = Astro.props;
const logoUrl = "https://mma2k.com/wp-content/uploads/2025/03/logo-mma-2k-300x75-1.png";
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | MMA2K</title>
</head>
<body class="bg-[#050505] text-white font-sans selection:bg-red-600">

    <header class="bg-black/90 backdrop-blur-xl border-b border-white/5 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 h-28 flex items-center justify-between">
            <a href="/" class="hover:scale-105 transition-all shrink-0">
                <img src={logoUrl} alt="MMA2K Logo" class="h-16 w-auto object-contain" />
            </a>

            <nav class="hidden md:flex items-center gap-12">
                <ul class="flex gap-10 text-[18px] font-black uppercase tracking-tighter italic text-gray-400">
                    <li><a href="/noticias" class="hover:text-white hover:border-b-4 border-red-600 pb-2 transition-all">NOTICIAS</a></li>
                    <li><a href="/carteleras" class="hover:text-red-500 transition-all">CARTELERAS</a></li>
                    <li><a href="/noticias" class="hover:text-red-500 transition-all">RANKINGS</a></li>
                </ul>
                <div class="h-10 w-[2px] bg-white/10 mx-4"></div>
                <a href="/ufc-326" class="bg-red-600 hover:bg-white hover:text-black text-white px-8 py-3 font-black uppercase italic tracking-widest transition-all shadow-xl">UFC EN VIVO</a>
            </nav>
        </div>
    </header>

    <slot />

    <footer class="bg-black border-t border-white/5 pt-24 pb-12 mt-32 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-16 mb-20 text-center md:text-left">
                <div class="space-y-6">
                    <img src={logoUrl} alt="Logo" class="h-10 mx-auto md:mx-0 opacity-80" />
                    <p class="text-gray-500 text-[11px] font-bold uppercase italic tracking-widest leading-relaxed">La autoridad número uno en MMA de RD. Parte de 2K Network.</p>
                </div>
                <div>
                    <h4 class="text-white font-black text-xs uppercase tracking-[0.3em] mb-10 border-l-4 border-red-600 pl-4 italic">UFC DIRECTO</h4>
                    <ul class="space-y-4 text-[11px] font-black uppercase tracking-widest text-gray-400">
                        <li><a href="/carteleras" class="hover:text-red-600">PRÓXIMAS PELEAS</a></li>
                        <li><a href="/noticias" class="hover:text-red-600">RANKINGS P4P</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-black text-xs uppercase tracking-[0.3em] mb-10 border-l-4 border-red-600 pl-4 italic">NUESTRA RED</h4>
                    <ul class="space-y-4 text-[11px] font-black uppercase tracking-widest text-gray-400">
                        <li><a href="https://luchalibre2k.com" class="hover:text-blue-500 italic">LUCHALIBRE2K.COM ↗</a></li>
                        <li><a href="#" class="hover:text-yellow-500 italic">PURO CARNAVAL ↗</a></li>
                    </ul>
                </div>
                <div class="bg-white/5 p-8 rounded-[2rem] border border-white/10">
                    <p class="text-red-600 font-black text-[10px] uppercase mb-4 italic">SUSCRÍBETE</p>
                    <input type="email" placeholder="TU EMAIL" class="w-full bg-black border border-white/10 rounded-xl px-4 py-3 text-[10px] font-black uppercase mb-3 outline-none focus:border-red-600" />
                    <button class="w-full bg-red-600 py-3 rounded-xl font-black uppercase text-[10px] italic">UNIRSE</button>
                </div>
            </div>
            <div class="border-t border-white/5 pt-12 text-center">
                <p class="text-gray-700 text-[9px] font-black uppercase tracking-[0.4em] italic">© 2026 MMA2K NETWORK | SANTIAGO, REP. DOM.</p>
            </div>
        </div>
    </footer>
</body>
</html>